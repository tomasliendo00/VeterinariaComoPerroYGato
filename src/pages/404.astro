---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada | Como Perro y Gato">
  <main class="min-h-screen flex flex-col items-center justify-center px-6 bg-background text-center">
    <span class="material-symbols-outlined text-primary mb-6" style="font-size: 80px;">pets</span>
    <h1 class="font-display font-bold text-6xl text-on-surface mb-4">404</h1>
    <p class="text-xl text-on-surface-variant mb-2">Esta página se escapó del consultorio.</p>
    <p class="text-sm text-outline mb-10">La dirección que buscás no existe o fue movida.</p>
    <a
      href="/"
      class="bg-primary text-on-primary px-8 py-4 rounded-xl font-semibold hover:opacity-90 transition-opacity shadow-lg"
    >
      Volver al inicio
    </a>
  </main>
</Layout>
