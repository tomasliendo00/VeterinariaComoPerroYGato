---
const branches = [
  {
    name: 'Sucursal Casado',
    address: 'Mayor Fernando Juan Casado 1689, Córdoba',
    mapsUrl: 'https://maps.app.goo.gl/WuSdDyrzgRAxLsiZA',
  },
  // {
  //   name: 'Sucursal O\'Higgins',
  //   address: 'Bernardo O\'Higgins 5847, Córdoba',
  //   mapsUrl: 'https://maps.app.goo.gl/SBKvUm98A7E6ueB76',
  // },
  // {
  //   name: 'Sucursal Balnearia',
  //   address: 'Boulevard Bosco 63, Balnearia',
  //   mapsUrl: 'https://maps.app.goo.gl/4ASJyFtds7p71Wpo6',
  // },
];
---

<section id="contacto" class="py-20 px-6 md:px-16 bg-background scroll-mt-10">
  <div class="text-center mb-12">
    <h2 class="font-display font-bold text-3xl md:text-4xl text-on-surface mb-2">Contacto y Ubicación</h2>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <!-- Formulario -->
    <div class="bg-surface-container-low p-8 rounded-2xl">
      <form class="space-y-6">
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-2">Nombre Completo</label>
          <input
            type="text"
            placeholder="Tu nombre"
            class="w-full bg-surface rounded-xl p-4 border border-outline-variant focus:outline-none focus:ring-2 focus:ring-primary transition-all shadow-sm"
          />
        </div>
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-2">Email</label>
          <input
            type="email"
            placeholder="tu@email.com"
            class="w-full bg-surface rounded-xl p-4 border border-outline-variant focus:outline-none focus:ring-2 focus:ring-primary transition-all shadow-sm"
          />
        </div>
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-2">Mensaje</label>
          <textarea
            rows="4"
            placeholder="¿En qué podemos ayudarte?"
            class="w-full bg-surface rounded-xl p-4 border border-outline-variant focus:outline-none focus:ring-2 focus:ring-primary transition-all shadow-sm resize-none"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full bg-primary text-on-primary py-4 rounded-xl font-semibold hover:opacity-90 transition-opacity shadow-lg"
        >
          Enviar mensaje
        </button>
        <a
          href="https://wa.me/[TELÉFONO_WA]"
          target="_blank"
          rel="noopener noreferrer"
          class="w-full bg-[#25D366] text-white py-4 rounded-xl font-semibold flex items-center justify-center gap-2 hover:opacity-90 transition-opacity shadow-lg"
        >
          <span class="material-symbols-outlined">chat</span>
          Escribinos por WhatsApp
        </a>
      </form>
    </div>

    <!-- Mapa + dirección -->
    <div class="flex flex-col gap-4">
      <div class="rounded-2xl overflow-hidden border border-outline-variant shadow-sm w-full h-72 lg:h-full min-h-64">
        <iframe
          src="https://maps.google.com/maps?q=-31.4660398,-64.228117&output=embed&hl=es&z=16"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      {branches.map(({ name, address, mapsUrl }) => (
        <div class="bg-surface-container-low rounded-2xl p-5 border border-outline-variant flex items-center gap-4">
          <span class="material-symbols-outlined text-primary text-3xl shrink-0">location_on</span>
          <div>
            <h4 class="font-display font-semibold text-base text-on-surface mb-0.5">{name}</h4>
            <p class="text-sm text-on-surface-variant mb-1">{address}</p>
            <a
              href={mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-primary font-semibold hover:underline"
            >
              Abrir en Google Maps
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
