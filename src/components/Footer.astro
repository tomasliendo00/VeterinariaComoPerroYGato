---
const links = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#resenas', label: 'Reseñas' },
  { href: '#horarios', label: 'Horarios' },
];
---

<footer class="bg-surface-container-lowest border-t border-outline-variant py-16 px-6 md:px-16">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-12">
    <div>
      <p class="font-display font-bold text-2xl text-primary mb-4">Como Perro y Gato</p>
      <p class="text-sm text-on-surface-variant">Cuidado profesional y amoroso para tu mascota en la ciudad de Córdoba.</p>
    </div>

    <div>
      <h4 class="text-xs font-semibold text-primary uppercase tracking-widest mb-6">Explorar</h4>
      <ul class="space-y-3">
        {links.map(({ href, label }) => (
          <li>
            <a href={href} class="text-sm text-on-surface-variant hover:text-primary transition-colors">{label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="text-xs font-semibold text-primary uppercase tracking-widest mb-6">Sucursales</h4>
      <ul class="space-y-4">
        <li class="flex items-start gap-2 text-sm text-on-surface-variant">
          <span class="material-symbols-outlined text-secondary text-[18px] mt-0.5 shrink-0">location_on</span>
          <span>Mayor Fernando Juan Casado 1689, Córdoba</span>
        </li>
        <!-- <li class="flex items-start gap-2 text-sm text-on-surface-variant">
          <span class="material-symbols-outlined text-secondary text-[18px] mt-0.5 shrink-0">location_on</span>
          <span>Bernardo O'Higgins 5847, Córdoba</span>
        </li>
        <li class="flex items-start gap-2 text-sm text-on-surface-variant">
          <span class="material-symbols-outlined text-secondary text-[18px] mt-0.5 shrink-0">location_on</span>
          <span>Boulevard Bosco 63, Balnearia</span>
        </li> -->
        <li class="flex items-start gap-2 text-sm text-on-surface-variant">
          <span class="material-symbols-outlined text-secondary text-[18px] mt-0.5 shrink-0">phone</span>
          4947340
        </li>
        <li class="flex items-start gap-2 text-sm text-on-surface-variant">
          <span class="material-symbols-outlined text-secondary text-[18px] mt-0.5 shrink-0">mail</span>
          [EMAIL]
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-outline-variant pt-6 flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="text-xs text-outline">© 2026 Veterinaria Como Perro y Gato. Cuidado profesional y amoroso para tu mascota.</p>
    <div class="flex gap-6">
      <a href="#" class="text-xs text-outline hover:text-primary">Política de Privacidad</a>
    </div>
  </div>
</footer>
