<section class="relative h-[600px] md:h-[870px] flex items-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1450778869180-41d0601e046e?w=1920&h=1080&fit=crop&auto=format&q=80"
      alt="Perro blanco y gato gris abrazados en el pasto"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-background/70 md:hidden"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-background/90 via-background/40 to-transparent hidden md:block"></div>
  </div>

  <div class="relative z-10 px-6 md:px-16 max-w-2xl">
    <h1 class="font-display font-bold text-4xl md:text-5xl text-primary mb-4 leading-tight">
      Como Perro y Gato
    </h1>
    <p class="text-lg text-on-surface-variant mb-8 max-w-md">
      Tu mascota, nuestra pasión. Brindamos cuidado médico de excelencia con el amor y la calidez que ellos merecen.
    </p>
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="https://wa.me/[TELÉFONO_WA]" target="_blank" rel="noopener noreferrer" class="bg-primary text-on-primary px-8 py-4 rounded-full font-semibold text-sm text-center hover:shadow-lg active:scale-95 transition-all">
        Pedir turno
      </a>
      <a href="#servicios" class="border-2 border-primary text-primary px-8 py-4 rounded-full font-semibold text-sm text-center hover:bg-primary/5 transition-all">
        Ver Servicios
      </a>
    </div>
  </div>
</section>
