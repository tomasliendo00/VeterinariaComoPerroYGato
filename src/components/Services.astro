---
const services = [
  {
    icon: 'stethoscope',
    title: 'Consultas Veterinarias',
    description: 'Atención médica primaria y seguimiento de la salud general de perros y gatos.',
    accent: false,
  },
  {
    icon: 'medical_mask',
    title: 'Cirugía Veterinaria',
    description: 'Procedimientos quirúrgicos programados y de emergencia con capacidad para manejar casos complejos.',
    accent: false,
  },
  {
    icon: 'biotech',
    title: 'Diagnóstico y Laboratorio',
    description: 'Ecografías de alta resolución y análisis clínicos para diagnósticos precisos y rápidos.',
    accent: false,
  },
  {
    icon: 'night_shelter',
    title: 'Internación',
    description: 'Instalaciones para el cuidado continuo de mascotas que requieren observación y tratamiento prolongado.',
    accent: false,
  },
  {
    icon: 'vaccines',
    title: 'Vacunación',
    description: 'Planes de inmunización esenciales para la prevención de enfermedades.',
    accent: false,
  },
  {
    icon: 'content_cut',
    title: 'Peluquería',
    description: 'Servicios de estética e higiene para mantener el bienestar y la apariencia de los animales.',
    accent: false,
  },
];
---

<section id="servicios" class="py-20 px-6 md:px-16 bg-surface">
  <div class="text-center mb-12">
    <h2 class="font-display font-bold text-3xl md:text-4xl text-on-surface mb-3">Nuestros Servicios</h2>
    <div class="w-20 h-1 bg-secondary mx-auto rounded-full"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {services.map(({ icon, title, description, accent }) => (
      <div class="bg-surface-container-lowest p-8 rounded-xl shadow-sm hover:shadow-md transition-shadow group">
        <div class={`w-14 h-14 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform ${accent ? 'bg-error-container text-on-error-container' : 'bg-secondary-container text-on-secondary-container'}`}>
          <span class="material-symbols-outlined text-3xl">{icon}</span>
        </div>
        <h3 class={`font-display font-semibold text-2xl mb-3 ${accent ? 'text-error' : 'text-on-surface'}`}>{title}</h3>
        <p class="text-on-surface-variant">{description}</p>
      </div>
    ))}
  </div>
</section>
